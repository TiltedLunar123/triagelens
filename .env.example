# TriageLens environment variables
#
# Demo mode and the local Ollama provider need NO configuration at all.
# These values only matter if you use the Claude (Anthropic) provider.

# Server-side only. Read by the Netlify function in netlify/functions/analyze.mjs.
# Never expose this in client code or commit a real key.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used by the serverless function.
ANTHROPIC_MODEL=claude-haiku-4-5

# Optional client overrides for the local Ollama provider.
# VITE_OLLAMA_URL=http://localhost:11434
# VITE_OLLAMA_MODEL=llama3.1
